# ─────────────────────────────────────────────────────────────
# Base de données — Neon (PostgreSQL)
# Récupère ces URLs depuis le dashboard Neon (https://console.neon.tech).
# DATABASE_URL : connexion "pooled" (avec -pooler), utilisée par l'app.
# DIRECT_URL   : connexion directe (sans -pooler), utilisée par les migrations Prisma.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────
# Stockage des images — Vercel Blob
# Sur Vercel : crée un store Blob (Storage → Blob) et lie-le au projet,
# le token est alors injecté automatiquement.
# En local : copie le token depuis le dashboard Vercel (Storage → ton store → .env.local).
# ─────────────────────────────────────────────────────────────
BLOB_STORE_ID="store_fezv9JEqg8rNmyll"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_fezv9JEqg8rNmyll_mwzUcMR6b1hSkAodtukRnHZxXOi0q4"

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
APP_NAME="Portfolio"
APP_DESCRIPTION="Portfolio professionnel de développeur."
APP_URL="http://localhost:3000"
APP_ENV="development"

# ─────────────────────────────────────────────────────────────
# Admin — authentification du panneau /admin
# ADMIN_PASS_HASH est un hash bcrypt, compatible avec PHP password_hash().
# Génère-le avec :  node -e "console.log(require('bcryptjs').hashSync('TON_MOT_DE_PASSE', 10))"
# ADMIN_SESSION_SECRET signe le cookie de session (chaîne aléatoire longue).
# ─────────────────────────────────────────────────────────────
ADMIN_USER="admin"
ADMIN_PASS_HASH=""
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# ─────────────────────────────────────────────────────────────
# Email (SMTP via Nodemailer) — réception des messages de contact
# ─────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_ENCRYPTION="tls"
MAIL_FROM="no-reply@example.com"
MAIL_FROM_NAME="Portfolio"
MAIL_TO="owner@example.com"

# ─────────────────────────────────────────────────────────────
# Coordonnées affichées sur la page Contact
# ─────────────────────────────────────────────────────────────
OWNER_NAME="Stéphane Steven TOSSOUGBE"
OWNER_HEADLINE="Développeur backend • Web • Mobile • DevOps"
CONTACT_EMAIL="owner@example.com"
CONTACT_LOCATION=""
CONTACT_AVAILABILITY=""
SOCIAL_GITHUB=""
SOCIAL_LINKEDIN=""
SOCIAL_TWITTER=""
SOCIAL_FACEBOOK=""
SOCIAL_WHATSAPP=""
